# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-random-secret-key

# Server
HOST=0.0.0.0
PORT=5000

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=http://localhost:3000

# File Upload
MAX_CONTENT_LENGTH=16777216

# Default crop values (pixels to remove from each side)
CROP_TOP=0
CROP_BOTTOM=0
CROP_LEFT=0
CROP_RIGHT=0

# Storage cleanup policy (to prevent uploads/outputs from growing forever)
# Enable/disable automatic cleanup (1=enabled, 0=disabled)
AUTO_CLEANUP_ENABLED=1
# Minimum seconds between cleanup runs
CLEANUP_INTERVAL_SECONDS=60
# Delete uploaded files older than this many hours
UPLOAD_RETENTION_HOURS=24
# Delete output files older than this many hours
OUTPUT_RETENTION_HOURS=24
# Keep at most this many files in uploads (oldest removed first)
UPLOAD_MAX_FILES=1000
# Keep at most this many files in outputs (oldest removed first)
OUTPUT_MAX_FILES=2000
